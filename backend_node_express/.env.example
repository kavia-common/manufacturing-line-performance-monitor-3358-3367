# Backend Node/Express (Ocean OEE) - environment variables
# NOTE: In this project, backend env vars are also named with REACT_APP_* for parity with the frontend deployment wiring.

# Server
REACT_APP_PORT=8080
REACT_APP_NODE_ENV=development
REACT_APP_TRUST_PROXY=false
REACT_APP_LOG_LEVEL=info
REACT_APP_HEALTHCHECK_PATH=/healthz

# CORS / origins
# Use REACT_APP_FRONTEND_URL to allow SPA origin, e.g. https://...:3000
REACT_APP_FRONTEND_URL=http://localhost:3000

# Public URLs (optional, for documentation/links)
REACT_APP_BACKEND_URL=http://localhost:8080
REACT_APP_API_BASE=http://localhost:8080

# Real-time
# For WS client: ws://localhost:8080/ws (or wss://.../ws)
REACT_APP_WS_URL=ws://localhost:8080/ws

# Auth
JWT_SECRET=change-me
JWT_ISSUER=ocean-oee
JWT_AUDIENCE=ocean-oee-spa
JWT_EXPIRES_IN=8h

# Feature toggles
REACT_APP_FEATURE_FLAGS={}
REACT_APP_EXPERIMENTS_ENABLED=false
