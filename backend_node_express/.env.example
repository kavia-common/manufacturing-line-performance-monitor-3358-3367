# Backend configuration
REACT_APP_PORT=8080
REACT_APP_NODE_ENV=development
REACT_APP_FRONTEND_URL=http://localhost:3000

# MongoDB (required for persistence)
# Example: mongodb://localhost:27017/oee_monitor
REACT_APP_MONGODB_URI=mongodb://localhost:27017/oee_monitor
# Optional override; often not needed when DB is in the URI path
REACT_APP_MONGODB_DB=oee_monitor

# JWT
JWT_SECRET=change-me
JWT_ISSUER=ocean-oee
JWT_AUDIENCE=ocean-oee-spa
JWT_EXPIRES_IN=8h
